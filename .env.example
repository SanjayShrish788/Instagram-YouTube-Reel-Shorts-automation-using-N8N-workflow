# Shared secrets
RENDER_API_KEY_INTERNAL=change-me-to-long-random-key

# Render API settings
VERSE_SOURCE=auto
BIBLE_API_BASE=https://bible-api.com
OUTPUT_BASE_URL=https://bible-render-api.onrender.com

# n8n settings
N8N_ENCRYPTION_KEY=replace-with-32-plus-char-secret
N8N_HOST=bible-shorts-n8n.onrender.com
N8N_EDITOR_BASE_URL=https://bible-shorts-n8n.onrender.com
WEBHOOK_URL=https://bible-shorts-n8n.onrender.com/
GENERIC_TIMEZONE=UTC

# Internal service route used by n8n
RENDER_API_BASE=https://bible-render-api.onrender.com

# YouTube metadata defaults used in workflow
YOUTUBE_PRIVACY_STATUS=public
YOUTUBE_CATEGORY_ID=22

# Optional alert hook for failures (Slack/Discord incoming webhook)
ALERT_WEBHOOK_URL=

# YouTube OAuth app info (used when configuring n8n YouTube credential)
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=
YOUTUBE_REFRESH_TOKEN=

# Multi-platform posting
POST_TARGET=both

# Instagram Graph API
INSTAGRAM_USER_ID=
INSTAGRAM_PAGE_ID=
INSTAGRAM_ACCESS_TOKEN=
INSTAGRAM_CAPTION_TEMPLATE=Trust God's timing. \ud83d\ude4f\nEven when you don't understand the path.\n\n#faith #motivation #bibleverse #trustgod #shorts

# Cloudinary for public video URL used by Instagram API
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_UNSIGNED_UPLOAD_PRESET=
