    {
      "parameters": {
        "resource": "video",
        "operation": "upload",
        "binaryProperty": "data",
        "title": "={{ (() => {\n  const name = String($json.name || '');\n  const marker = '__ref_';\n  const markerIdx = name.toLowerCase().lastIndexOf(marker);\n  \n  if (markerIdx < 0) return 'Bible Verse #Shorts';\n  \n  const raw0 = name.slice(markerIdx + marker.length);\n  const raw = raw0.toLowerCase().endsWith('.mp4') ? raw0.slice(0, -4).toLowerCase() : raw0.toLowerCase();\n  const us = raw.lastIndexOf('_');\n  \n  let verse = '';\n  let bookRaw = raw;\n  if (us > 0) {\n    verse = raw.slice(us + 1);\n    bookRaw = raw.slice(0, us);\n  }\n  \n  const capitalizeWord = (w) => w.charAt(0).toUpperCase() + w.slice(1).toLowerCase();\n  const bookWords = bookRaw.split('_').filter(w => w.length > 0);\n  const bookDisplay = bookWords.map(capitalizeWord).join(' ');\n  const verseDisplay = verse.split('_').join(':');\n  \n  if (bookDisplay && verseDisplay) {\n    return `${bookDisplay} ${verseDisplay} | Bible Verse #Shorts`;\n  }\n  \n  return 'Bible Verse #Shorts';\n})() }}",
        "description": "={{ (() => {\n  const name = String($json.name || '');\n  const marker = '__ref_';\n  const markerIdx = name.toLowerCase().lastIndexOf(marker);\n  \n  let verseRef = 'Bible Verse';\n  if (markerIdx >= 0) {\n    const raw0 = name.slice(markerIdx + marker.length);\n    const raw = raw0.toLowerCase().endsWith('.mp4') ? raw0.slice(0, -4).toLowerCase() : raw0.toLowerCase();\n    const us = raw.lastIndexOf('_');\n    \n    let verse = '';\n    let bookRaw = raw;\n    if (us > 0) {\n      verse = raw.slice(us + 1);\n      bookRaw = raw.slice(0, us);\n    }\n    \n    const capitalizeWord = (w) => w.charAt(0).toUpperCase() + w.slice(1).toLowerCase();\n    const bookWords = bookRaw.split('_').filter(w => w.length > 0);\n    const bookDisplay = bookWords.map(capitalizeWord).join(' ');\n    const verseDisplay = verse.split('_').join(':');\n    \n    if (bookDisplay && verseDisplay) {\n      verseRef = `${bookDisplay} ${verseDisplay}`;\n    }\n  }\n  \n  return `Trust in the Lord's word. \\n\\n${verseRef}\\n\\n#faith #motivation #bibleverse #trustgod #shorts #blessed`;\n})() }}",
        "categoryId": "={{$env.YOUTUBE_CATEGORY_ID || '22'}}",
        "privacyStatus": "={{$env.YOUTUBE_PRIVACY_STATUS || 'public'}}",
        "additionalFields": {
          "tags": "={{['Bible','Christian','Faith','Jesus','Shorts']}}"
        }
