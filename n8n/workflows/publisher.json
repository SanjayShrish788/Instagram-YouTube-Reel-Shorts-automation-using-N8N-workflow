    {
      "parameters": {
        "jsCode": "const raw = $input.all().filter((item) => item?.json?.id);\n\nconst dedup = [];\nconst seen = new Set();\nfor (const item of raw) {\n  const id = String(item.json.id);\n  if (seen.has(id)) continue;\n  seen.add(id);\n  dedup.push(item);\n}\n\nconst parseVideoNum = (name) => {\n  const m = String(name || '').match(/video_(\\d+)/i);\n  return m ? Number(m[1]) : Number.POSITIVE_INFINITY;\n};\n\nconst parseCreated = (item) => {\n  const t = Date.parse(String(item?.json?.createdTime || item?.json?.modifiedTime || ''));\n  return Number.isFinite(t) ? t : Number.MAX_SAFE_INTEGER;\n};\n\ndedup.sort((a, b) => {\n  const an = parseVideoNum(a?.json?.name);\n  const bn = parseVideoNum(b?.json?.name);\n  if (Number.isFinite(an) && Number.isFinite(bn) && an !== bn) return an - bn;\n  const dt = parseCreated(a) - parseCreated(b);\n  if (dt !== 0) return dt;\n  return String(a?.json?.name || '').localeCompare(String(b?.json?.name || ''));\n});\n\nif (dedup.length === 0) return [{ json: {} }];\nreturn dedup;"
      },
      "id": "16",
      "name": "Sort Queue Videos",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1460,
        220
      ]
    },
    {
      "parameters": {
        "jsCode": "const items = $input.all();\nconst BATCH_SIZE = 10;\nconst batch = items.slice(0, BATCH_SIZE);\n\nif (batch.length === 0) {\n  return [];\n}\n\nreturn batch.map(item => ({\n  json: item.json,\n  binary: item.binary\n}));"
      },
