      "id": "2",
      "name": "Check IG Quota",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        430,
        320
      ],
      "retryOnFail": true,
      "maxTries": 3,
      "waitBetweenTries": 3000
    },
    {
      "parameters": {
        "jsCode": "const payload = $json.data && $json.data[0] ? $json.data[0] : {};\nconst usage = Number(payload.quota_usage || 0);\nconst total = Number(payload.config?.quota_total || 25);\nconst remaining = Math.max(total - usage, 0);\n\nreturn [{\n  json: {\n    quotaUsage: usage,\n    quotaTotal: total,\n    quotaRemaining: remaining,\n    canPublish: usage < total,\n    queueFolderId: String($env.DRIVE_QUEUE_FOLDER_ID || ''),\n    postedFolderId: String($env.DRIVE_POSTED_FOLDER_ID || ''),\n    queueFolderPath: 'BibleShorts/queue',\n    postedFolderPath: 'BibleShorts/posted',\n    igUserId: String($env.INSTAGRAM_USER_ID || ''),\n    igAccessToken: String($env.INSTAGRAM_ACCESS_TOKEN || ''),\n    igCaptionTemplate: String($env.INSTAGRAM_CAPTION_TEMPLATE || '#bible #shorts #faith #reels')\n  }\n}];"
      },
