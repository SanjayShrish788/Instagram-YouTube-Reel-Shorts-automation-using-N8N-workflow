{
  "name": "Bible Shorts - Render + YouTube",
  "nodes": [
    {
      "parameters": {},
      "id": "1",
      "name": "Manual Trigger",
      "type": "n8n-nodes-base.manualTrigger",
      "typeVersion": 1,
      "position": [
        200,
        280
      ]
    },
    {
      "parameters": {
        "rule": {
          "interval": [
            {
              "field": "hours",
              "hoursInterval": 6
            }
          ]
        }
      },
      "id": "2",
      "name": "Cron Trigger",
      "type": "n8n-nodes-base.scheduleTrigger",
      "typeVersion": 1.2,
      "position": [
        200,
        480
      ]
    },
    {
      "parameters": {
        "mode": "append"
      },
      "id": "3",
      "name": "Merge Triggers",
      "type": "n8n-nodes-base.merge",
      "typeVersion": 3,
      "position": [
        420,
        380
      ]
    },
    {
      "parameters": {
        "method": "GET",
        "url": "={{$env.RENDER_API_BASE + '/verses/random'}}",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "x-api-key",
              "value": "={{$env.RENDER_API_KEY_INTERNAL}}"
            }
          ]
        },
        "sendQuery": true,
        "queryParameters": {
          "parameters": [
            {
              "name": "source",
              "value": "={{$env.VERSE_SOURCE || 'auto'}}"
            }
          ]
        },
        "options": {}
      },
      "id": "4",
      "name": "Get Random Verse",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        660,
        320
      ],
      "retryOnFail": true,
      "maxTries": 3,
      "waitBetweenTries": 2000
    },
    {
      "parameters": {
        "method": "GET",
        "url": "={{$env.RENDER_API_BASE + '/music-files'}}",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "x-api-key",
              "value": "={{$env.RENDER_API_KEY_INTERNAL}}"
            }
          ]
        },
        "options": {}
      },
      "id": "5",
      "name": "Get Music Files",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        660,
        460
      ],
      "retryOnFail": true,
      "maxTries": 3,
      "waitBetweenTries": 2000
    },
    {
      "parameters": {
        "jsCode": "const verse = $items('Get Random Verse')[0].json;\nconst music = $items('Get Music Files')[0].json;\n\nconst files = Array.isArray(music.files) ? music.files : [];\nconst selectedMusic = files.length ? files[Math.floor(Math.random() * files.length)] : '';\n\nconst duration = 6 + Math.random() * 2;\nconst now = new Date();\nconst datePart = now.toISOString().slice(0,10).replace(/-/g, '');\nconst timePart = now.toISOString().slice(11,19).replace(/:/g, '');\nconst outputName = `bible_short_${datePart}_${timePart}.mp4`;\n\nconst verseText = String(verse.text || '').trim();\nconst reference = String(verse.reference || '').trim();\n\nconst titleBase = `${reference} | Bible Verse #Shorts`;\nconst title = titleBase.length > 95 ? `${titleBase.slice(0, 92)}...` : titleBase;\n\nconst devotional = 'God\'s Word is living and active, speaking peace and strength for today.';\nconst description = [\n  'Daily Bible Short for faith and encouragement.',\n  '',\n  `${verseText}`,\n  `${reference}`,\n  '',\n  devotional,\n  '',\n  'Subscribe for daily Scripture shorts.',\n  '#Shorts #Bible #Christian #Faith #Jesus'\n].join('\\n');\n\nreturn [{\n  json: {\n    verse: verseText,\n    reference,\n    source: verse.source || 'unknown',\n    music_file: selectedMusic,\n    output_name: outputName,\n    duration: Number(duration.toFixed(2)),\n    title,\n    description,\n    tags: ['Bible','Christian','Faith','Jesus','Scripture','Shorts'],\n    privacyStatus: $env.YOUTUBE_PRIVACY_STATUS || 'public',\n    categoryId: $env.YOUTUBE_CATEGORY_ID || '22'\n  }\n}];"
      },
      "id": "6",
      "name": "Build Short Payload",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        900,
        380
      ]
    },
    {
      "parameters": {
        "method": "GET",
        "url": "={{$env.RENDER_API_BASE + '/uploads/check'}}",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "x-api-key",
              "value": "={{$env.RENDER_API_KEY_INTERNAL}}"
            }
          ]
        },
        "sendQuery": true,
        "queryParameters": {
          "parameters": [
            {
              "name": "verse",
              "value": "={{$json.verse}}"
            },
            {
              "name": "reference",
              "value": "={{$json.reference}}"
            }
          ]
        },
        "options": {}
      },
      "id": "7",
      "name": "Check Duplicate Today",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        1140,
        380
      ]
    },
    {
      "parameters": {
        "conditions": {
          "boolean": [
            {
              "value1": "={{$json.duplicate}}",
              "value2": true
            }
          ]
        }
      },
      "id": "8",
      "name": "Already Uploaded?",
      "type": "n8n-nodes-base.if",
      "typeVersion": 2,
      "position": [
        1360,
        380
      ]
    },
    {
      "parameters": {
        "assignments": {
          "assignments": [
            {
              "name": "message",
              "value": "Duplicate verse/reference today. Upload skipped.",
              "type": "string"
            }
          ]
        },
        "options": {}
      },
      "id": "9",
      "name": "Skip Duplicate",
      "type": "n8n-nodes-base.set",
      "typeVersion": 3.4,
      "position": [
        1580,
        300
      ]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "={{$env.RENDER_API_BASE + '/render'}}",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "x-api-key",
              "value": "={{$env.RENDER_API_KEY_INTERNAL}}"
            }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={{ ({\n  verse: $item(0).$node['Build Short Payload'].json.verse,\n  reference: $item(0).$node['Build Short Payload'].json.reference,\n  duration: $item(0).$node['Build Short Payload'].json.duration,\n  music_file: $item(0).$node['Build Short Payload'].json.music_file || '',\n  output_name: $item(0).$node['Build Short Payload'].json.output_name\n}) }}",
        "options": {}
      },
      "id": "10",
      "name": "Render Short",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        1580,
        460
      ],
      "retryOnFail": true,
      "maxTries": 3,
      "waitBetweenTries": 3000
    },
    {
      "parameters": {
        "method": "GET",
        "url": "={{$env.RENDER_API_BASE + '/files/' + $item(0).$node['Build Short Payload'].json.output_name}}",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "x-api-key",
              "value": "={{$env.RENDER_API_KEY_INTERNAL}}"
            }
          ]
        },
        "options": {},
        "responseFormat": "file",
        "outputPropertyName": "data"
      },
      "id": "11",
      "name": "Download Video",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        1810,
        460
      ]
    },
    {
      "parameters": {
        "resource": "video",
        "operation": "upload",
        "binaryProperty": "data",
        "title": "={{$item(0).$node['Build Short Payload'].json.title}}",
        "description": "={{$item(0).$node['Build Short Payload'].json.description}}",
        "categoryId": "={{$item(0).$node['Build Short Payload'].json.categoryId}}",
        "privacyStatus": "={{$item(0).$node['Build Short Payload'].json.privacyStatus}}",
        "additionalFields": {
          "tags": "={{$item(0).$node['Build Short Payload'].json.tags}}"
        }
      },
      "id": "12",
      "name": "Upload to YouTube",
      "type": "n8n-nodes-base.youTube",
      "typeVersion": 1,
      "position": [
        2030,
        460
      ],
      "credentials": {
        "youTubeOAuth2Api": {
          "name": "YouTube OAuth2"
        }
      }
    },
    {
      "parameters": {
        "method": "POST",
        "url": "={{$env.RENDER_API_BASE + '/record-upload'}}",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "x-api-key",
              "value": "={{$env.RENDER_API_KEY_INTERNAL}}"
            }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={{ ({\n  verse: $item(0).$node['Build Short Payload'].json.verse,\n  reference: $item(0).$node['Build Short Payload'].json.reference,\n  output_name: $item(0).$node['Build Short Payload'].json.output_name,\n  youtube_video_id: $json.id || $json.videoId || null,\n  title: $item(0).$node['Build Short Payload'].json.title,\n  description: $item(0).$node['Build Short Payload'].json.description,\n  tags: $item(0).$node['Build Short Payload'].json.tags,\n  privacy_status: $item(0).$node['Build Short Payload'].json.privacyStatus,\n  status: 'uploaded'\n}) }}",
        "options": {}
      },
      "id": "13",
      "name": "Record Upload",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        2250,
        460
      ]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "={{$env.ALERT_WEBHOOK_URL}}",
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={{ ({ message: 'Bible Shorts workflow failure', workflow: $workflow.name, executionId: $execution.id }) }}",
        "options": {}
      },
      "id": "14",
      "name": "Alert Webhook (Optional)",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        1810,
        660
      ],
      "disabled": true
    }
  ],
  "connections": {
    "Manual Trigger": {
      "main": [
        [
          {
            "node": "Merge Triggers",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "Cron Trigger": {
      "main": [
        [
          {
            "node": "Merge Triggers",
            "type": "main",
            "index": 1
          }
        ]
      ]
    },
    "Merge Triggers": {
      "main": [
        [
          {
            "node": "Get Random Verse",
            "type": "main",
            "index": 0
          },
          {
            "node": "Get Music Files",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "Get Random Verse": {
      "main": [
        [
          {
            "node": "Build Short Payload",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "Get Music Files": {
      "main": [
        [
          {
            "node": "Build Short Payload",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "Build Short Payload": {
      "main": [
        [
          {
            "node": "Check Duplicate Today",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "Check Duplicate Today": {
      "main": [
        [
          {
            "node": "Already Uploaded?",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "Already Uploaded?": {
      "main": [
        [
          {
            "node": "Skip Duplicate",
            "type": "main",
            "index": 0
          }
        ],
        [
          {
            "node": "Render Short",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "Render Short": {
      "main": [
        [
          {
            "node": "Download Video",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "Download Video": {
      "main": [
        [
          {
            "node": "Upload to YouTube",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "Upload to YouTube": {
      "main": [
        [
          {
            "node": "Record Upload",
            "type": "main",
            "index": 0
          }
        ]
      ]
    }
  },
  "settings": {
    "executionOrder": "v1"
  },
  "pinData": {},
  "active": false,
  "versionId": "1"
}
