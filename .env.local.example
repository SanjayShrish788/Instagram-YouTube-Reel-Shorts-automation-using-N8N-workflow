# Local stack secrets
RENDER_API_KEY_INTERNAL=replace-with-strong-random-secret
N8N_ENCRYPTION_KEY=replace-with-32-char-or-longer-secret

# Optional overrides
VERSE_SOURCE=auto
BIBLE_API_BASE=https://bible-api.com
OUTPUT_BASE_URL=http://localhost:10000
GENERIC_TIMEZONE=UTC
YOUTUBE_PRIVACY_STATUS=public
YOUTUBE_CATEGORY_ID=22
ALERT_WEBHOOK_URL=

# Multi-platform posting
POST_TARGET=both

# Instagram Graph API
INSTAGRAM_USER_ID=
INSTAGRAM_PAGE_ID=
FACEBOOK_PAGE_ID=
INSTAGRAM_ACCESS_TOKEN=
INSTAGRAM_CAPTION_TEMPLATE=Trust God's timing.\nEven when you don't understand the path.\n\n#faith #motivation #bibleverse #trustgod #shorts

# Cloudinary for public video URL used by Instagram API
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_UNSIGNED_UPLOAD_PRESET=

# Queue/posted Drive folders used by publisher and creator
DRIVE_QUEUE_FOLDER_ID=
DRIVE_POSTED_FOLDER_ID=

# Optional operational settings
DEFAULT_MUSIC_FILE=
SKIP_DUPLICATE_CHECK=false
DAILY_BATCH_SIZE=10
NO_REPEAT_DAYS=36500
MAX_VERSE_FETCH_ATTEMPTS=120
NOTIFY_EMAIL_TO=
